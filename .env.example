# Copy this file to functions/.env and fill in the real values.
# Do NOT put BKASH_APP_KEY / BKASH_APP_SECRET / BKASH_USERNAME / BKASH_PASSWORD
# here — those are set separately as encrypted secrets (see DEPLOY.md), never
# as plain .env values, since .env files are not encrypted.

# Sandbox for testing:
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
# Production (switch to this when you're ready to go live):
# BKASH_BASE_URL=https://tokenized.pay.bka.sh/v1.2.0-beta

# This gets filled in AFTER your first deploy, once Firebase gives you the
# real URL for the bkashCallback function (see DEPLOY.md step 5).
BKASH_CALLBACK_URL=https://us-central1-eloria-care.cloudfunctions.net/bkashCallback

# Your live site's URL (used to redirect the customer back after payment).
SITE_URL=https://your-site.vercel.app
